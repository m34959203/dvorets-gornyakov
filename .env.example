# Database
DATABASE_URL=postgresql://dvorets:dvorets_pass@localhost:5432/dvorets_db

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
INSTAGRAM_ACCOUNT_ID=your-account-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=kk

# Upload
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# AI kill-switch + USD-cap (низкоприоритетный проект, kill-switch only защита).
# AI_DISABLED=1 → каждый chatWithGemini() возвращает UNAVAILABLE_REPLY без сети.
# DO NOT SET AI_DISABLED=0 unless polled assertUsdBudget integration:
# когда станет активным — добавить guard через src/lib/ai-usage.ts (есть withinBudget).
AI_DISABLED=1
AI_USD_CAP_DAILY=0.05
AI_USD_CAP_TOTAL=0.10
AI_USD_CAP_PERIOD_START=2026-04-30
