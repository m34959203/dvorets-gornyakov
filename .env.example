# Database
DATABASE_URL=postgresql://dvorets:dvorets_pass@localhost:5432/dvorets_db

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string

# Gemini AI (чат-бот + бот аренды зала через function calling)
# ВАЖНО: для работы бот-брони нужен реальный GEMINI_API_KEY И AI_DISABLED НЕ должен быть =1.
# Без ключа/при AI_DISABLED=1 бот отвечает дружелюбным fallback (без 500), но tool book_hall не сработает.
GEMINI_API_KEY=your-gemini-api-key
# Опционально (будущий primary-провайдер, fallback на Gemini): GROQ_API_KEY=gsk_...
# ADMIN_EMAIL=admin@dvorets-gornyakov.kz   # для e-mail уведомлений о брони (пока не реализовано)

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
INSTAGRAM_ACCOUNT_ID=your-account-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=kk

# Upload
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# AI kill-switch + USD-cap (низкоприоритетный проект, kill-switch only защита).
# AI_DISABLED=1 → каждый chatWithGemini() возвращает UNAVAILABLE_REPLY без сети.
# DO NOT SET AI_DISABLED=0 unless polled assertUsdBudget integration:
# когда станет активным — добавить guard через src/lib/ai-usage.ts (есть withinBudget).
AI_DISABLED=1
AI_USD_CAP_DAILY=0.05
AI_USD_CAP_TOTAL=0.10
AI_USD_CAP_PERIOD_START=2026-04-30
